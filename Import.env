# --- RENDER ENVIRONMENT VARIABLES ---
# Salin semua isi file ini ke bagian "Import from .env" di Render Environment Group
# atau di masing-masing Web Service Environment Variables.

# 1. Database Configuration
# Dapatkan ini dari menu "Database" di Render (Internal Database URL lebih baik)
DATABASE_URL=postgres://user:password@internal-db-host:5432/manda_db

# 2. API Configuration (apps/api)
NODE_ENV=production
PORT=10000
BETTER_AUTH_SECRET=GANTI_DENGAN_RANDOM_STRING_YANG_PANJANG
BETTER_AUTH_URL=https://manda-api.onrender.com
FRONTEND_URL=https://mandaapp-web.vercel.app

# 3. Web Configuration (apps/web)
# Pastikan URL ini sesuai dengan URL API Anda di Render
VITE_API_URL=https://manda-api.onrender.com/api
VITE_AUTH_URL=https://manda-api.onrender.com

# 4. Other (Optional)
# Jika Anda menggunakan upload gambar ke cloud (misal: Cloudinary/S3)
# CLOUDINARY_URL=
# AWS_ACCESS_KEY_ID=
